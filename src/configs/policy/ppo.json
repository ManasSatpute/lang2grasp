{
  "algo": "PPO",
  "seed": 0,
  "total_timesteps": 5000000,

  "n_envs": 10,
  "n_threads": 2,
  "device": "auto",

  "normalize_obs": true,
  "normalize_reward": true,

  "checkpoint_freq": 100000,
  "eval_freq": 50000,
  "n_eval_episodes": 10,
  "save_replay_buffer": false,

  "max_hours": 3.75,
  "resume": true,

  "policy_kwargs": {
    "net_arch": [256, 256]
  },

  "algo_kwargs": {
    "learning_rate": 0.0003,
    "n_steps": 512,
    "batch_size": 1280,
    "n_epochs": 10,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_range": 0.2,
    "ent_coef": 0.0,
    "vf_coef": 0.5,
    "max_grad_norm": 0.5
  },

  "env": {
    "task": "Lift",
    "robot": "Panda",
    "controller": "OSC_POSE",
    "horizon": 500,
    "control_freq": 20,
    "reward_shaping": true,
    "terminate_on_success": false
  }
}
